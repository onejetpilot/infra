{
  "interpreterSettings": {
    "spark": {
      "id": "spark",
      "name": "spark",
      "group": "spark",
      "properties": {
        "master": "spark://spark-master:7077",
        "spark.master": "spark://spark-master:7077",
        "spark.submit.deployMode": "client",
        "spark.sql.catalogImplementation": "hive",
        "spark.hadoop.hive.metastore.uris": "thrift://hive-metastore:9083",
        "spark.sql.hive.metastore.version": "3.1.3",
        "spark.sql.hive.metastore.jars": "path",
        "spark.sql.hive.metastore.jars.path": "file:///opt/hive/lib/*",
        "spark.sql.warehouse.dir": "hdfs://namenode:8020/user/hive/warehouse"
      },
      "dependencies": [],
      "option": {"remote": true, "isExistingProcess": false, "setPermission": false},
      "interpreterGroup": [
        {"name": "spark", "class": "org.apache.zeppelin.spark.SparkInterpreter", "defaultInterpreter": true},
        {"name": "pyspark", "class": "org.apache.zeppelin.spark.PySparkInterpreter", "defaultInterpreter": false},
        {"name": "sql", "class": "org.apache.zeppelin.spark.SparkSqlInterpreter", "defaultInterpreter": false}
      ]
    },
    "sh": {
      "id": "sh",
      "name": "sh",
      "group": "sh",
      "properties": {},
      "dependencies": [],
      "option": {"remote": true, "isExistingProcess": false, "setPermission": false},
      "interpreterGroup": [{"name": "sh", "class": "org.apache.zeppelin.shell.ShellInterpreter", "defaultInterpreter": true}]
    },
    "jdbc-hive": {
      "id": "jdbc-hive",
      "name": "jdbc",
      "group": "jdbc",
      "properties": {
        "default.url": "jdbc:hive2://hiveserver2:10000/default",
        "default.user": "__HDFS_USER__",
        "default.password": "",
        "default.driver": "org.apache.hive.jdbc.HiveDriver"
      },
      "dependencies": [{"groupArtifactVersion": "org.apache.hive:hive-jdbc:3.1.3", "local": false}],
      "option": {"remote": true, "isExistingProcess": false, "setPermission": false},
      "interpreterGroup": [{"name": "sql", "class": "org.apache.zeppelin.jdbc.JDBCInterpreter", "defaultInterpreter": true}]
    }
  }
}
